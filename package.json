{
	"name": "@superbuilders/limiter",
	"version": "0.1.0",
	"description": "Concurrency limiter primitive for Superbuilders applications",
	"module": "dist/limiter.js",
	"main": "dist/limiter.js",
	"types": "dist/limiter.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/limiter.d.ts",
			"import": "./dist/limiter.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run build.ts",
		"typecheck": "tsgo --noEmit",
		"prepublishOnly": "bun run build"
	},
	"keywords": [
		"concurrency",
		"limiter",
		"superbuilders"
	],
	"author": "Bjorn Pagen",
	"license": "0BSD",
	"repository": {
		"type": "git",
		"url": "https://github.com/superbuilders/limiter"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@superbuilders/errors": "^3.0.2"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@typescript/native-preview": "^7.0.0-dev.20260612.1",
		"resolve-tspaths": "^0.8.23",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=18"
	}
}
