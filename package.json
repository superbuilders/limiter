{
	"name": "@superbuilders/limiter",
	"version": "1.0.1",
	"description": "Concurrency limiter primitive for Superbuilders applications",
	"module": "dist/limiter.js",
	"main": "dist/limiter.js",
	"types": "dist/limiter.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/limiter.d.ts",
			"default": "./dist/limiter.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm run build",
		"test": "pnpm run build && node --test src/limiter.test.ts"
	},
	"keywords": [
		"concurrency",
		"limiter",
		"superbuilders"
	],
	"author": "Bjorn Pagen",
	"license": "0BSD",
	"repository": {
		"type": "git",
		"url": "https://github.com/superbuilders/limiter"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@superbuilders/errors": "^4.0.0"
	},
	"devDependencies": {
		"typescript": "^7.0.2",
		"@types/node": "^26.1.0"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@11.9.0",
	"imports": {
		"#*.ts": {
			"types": "./src/*.ts",
			"default": "./dist/*.js"
		}
	}
}
